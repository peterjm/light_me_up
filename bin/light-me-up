#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/light_me_up"
require "optparse"

options = {}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: #{$PROGRAM_NAME} [options]"

  opts.on("-T", "--toggle", "Toggle whether the lights are on or off") { options[:toggle] = true }
  opts.on("--on", "Turn the light on") { options[:on] = true }
  opts.on("-O", "--off", "Turn the light off") { options[:on] = false }
  opts.on("--ip-address ADDR", "Specify the IP address") { |addr| options[:ip_address] = addr }
  opts.on("--defaults", "Set to default values") { options[:defaults] = true }
  opts.on("--brightness N", Integer,
          "Set the brightness (#{LightMeUp::Light.min_brightness} to #{LightMeUp::Light.max_brightness})") do |n|
    options[:brightness] = n
  end
  opts.on("--temperature N", Integer,
          "Set the temperature (#{LightMeUp::Light.min_temperature} to #{LightMeUp::Light.max_temperature})") do |n|
    options[:temperature] = n
  end
  opts.on("--version", "Print version number and exit") do
    puts "light-me-up #{LightMeUp::VERSION}"
    exit
  end
end

parser.parse!

options[:ip_address] ||= ENV.fetch("ELGATO_IP_ADDRESS", nil)

if options.delete(:defaults)
  options = {
    brightness: ENV.fetch("ELGATO_DEFAULT_BRIGHTNESS").to_i,
    temperature: ENV.fetch("ELGATO_DEFAULT_TEMPERATURE").to_i,
  }.merge(options)
end

api_client = LightMeUp::ApiClient.new(ip_address: options[:ip_address])

begin
  LightMeUp::SettingsUpdate.new(api_client, options).perform
rescue LightMeUp::SettingsUpdate::ToggleIncompatible => e
  abort "Error: --toggle #{e.message}"
rescue LightMeUp::SettingsUpdate::InvalidOptions => e
  warn e.message
  warn parser
  exit 1
rescue LightMeUp::Error => e
  abort e.message
end
